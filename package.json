{
    "name": "opentrace",
    "displayName": "OpenTrace",
    "description": "Interactive VCD waveform viewer for FPGA/RTL developers",
    "publisher": "opentrace",
    "version": "1.0.0",
    "keywords": [
        "VCD",
        "waveform",
        "graph",
        "fpga",
        "verilog",
        "vhdl"
    ],
    "extensionKind": [
        "ui",
        "workspace"
    ],
    "qna": false,
    "engines": {
        "vscode": "^1.46.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCustomEditor:opentrace.vcd"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [],
        "customEditors": [
            {
                "viewType": "opentrace.vcd",
                "displayName": "OpenTrace VCD",
                "selector": [
                    {
                        "filenamePattern": "*.vcd"
                    }
                ]
            }
        ],
        "jsonValidation": [
            {
                "fileMatch": "config.opentrace.json",
                "url": "./schemas/opentrace.schema.json"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run build:webview && webpack --mode production",
        "compile": "webpack --mode development",
        "watch": "webpack --mode development --watch",
        "build:webview": "cd webview-app && npm run build",
        "test-compile": "tsc -p ./",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "format": "prettier --write \"src/**/*.ts\" \"*.json\" \".vscode/**/*.json\" \"schemas/**/*.json\""
    },
    "devDependencies": {
        "@types/glob": "^7.1.1",
        "@types/mocha": "^7.0.2",
        "@types/node": "^13.11.0",
        "@types/vscode": "^1.46.0",
        "@typescript-eslint/eslint-plugin": "^7.18.0",
        "@typescript-eslint/parser": "^7.18.0",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "glob": "^7.1.6",
        "mocha": "^7.1.2",
        "prettier": "^3.8.1",
        "terser-webpack-plugin": "~5.3.0",
        "ts-loader": "~9.5.0",
        "typescript": "~4.9.0",
        "vscode-test": "^1.3.0",
        "webpack": "~5.90.0",
        "webpack-cli": "~5.1.0"
    }
}
